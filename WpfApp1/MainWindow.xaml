<Window x:Class="WpfApp1.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp1.ViewModels"
        xmlns:conv="clr-namespace:WpfApp1.Converters"
        Title="QuickDock"
        Width="360" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:EmptyCollectionVisibilityConverter x:Key="EmptyVis"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border x:Name="RootBorder"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True"
            AllowDrop="True"
            PreviewMouseLeftButtonDown="RootBorder_PreviewMouseLeftButtonDown"
            Drop="RootBorder_Drop"
            DragOver="RootBorder_DragOver">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSecondaryBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="TitleBarIcon" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="QuickDock" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButton}" ToolTip="添加文件或文件夹"
                                Command="{Binding AddItemsCommand}" Padding="6">
                            <TextBlock Text="＋" FontSize="14" FontWeight="Bold"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" ToolTip="设置"
                                Command="{Binding OpenSettingsCommand}" Padding="6" Margin="2,0,0,0">
                            <TextBlock Text="🔧" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" ToolTip="隐藏到任务栏"
                                Command="{Binding HideToTrayCommand}" Padding="6" Margin="2,0,0,0">
                            <TextBlock Text="−" FontSize="14" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Border Grid.Row="1"
                    CornerRadius="0,0,12,12"
                    ClipToBounds="True">
                <Grid>
                    <Grid Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Categories -->
                        <Border Background="{StaticResource BgSecondaryBrush}"
                                Margin="0,0,1,0"
                                CornerRadius="0,0,0,12"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListBox x:Name="CategoryListBox"
                                         ItemsSource="{Binding Categories}"
                                         SelectedItem="{Binding SelectedCategory}"
                                         PreviewMouseRightButtonDown="CategoryListBox_PreviewMouseRightButtonDown"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Margin="4,8">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource CategoryItem}"/>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ContextMenu>
                                        <ContextMenu Opened="ContextMenu_Opened">
                                            <MenuItem Header="重命名" Click="RenameCategoryMenuItem_Click"/>
                                            <MenuItem Header="删除" Click="DeleteCategoryMenuItem_Click"/>
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                </ListBox>

                                <Button Grid.Row="1" Content="+ 分类" Style="{StaticResource ModernButton}"
                                        Margin="8" FontSize="12"
                                        Command="{Binding AddCategoryCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Items Grid -->
                        <ScrollViewer Grid.Column="1"
                                      x:Name="LaunchItemsScrollViewer"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      AllowDrop="True"
                                      DragOver="LaunchItemsArea_DragOver"
                                      Drop="LaunchItemsArea_Drop"
                                      Padding="4">
                            <ItemsControl x:Name="LaunchItemsControl"
                                          ItemsSource="{Binding FilteredItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource LaunchItemCard}"
                                                AllowDrop="True"
                                                DragOver="ItemCard_DragOver"
                                                Drop="ItemCard_Drop"
                                                MouseLeftButtonDown="ItemCard_MouseLeftButtonDown"
                                                MouseMove="ItemCard_MouseMove"
                                                MouseLeftButtonUp="ItemCard_MouseLeftButtonUp"
                                                Tag="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu Opened="ContextMenu_Opened">
                                                    <MenuItem Header="修改名称和图标" Click="EditItemMenuItem_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="删除" Click="DeleteItemMenuItem_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Image Source="{Binding Icon}" Width="40" Height="40"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <TextBlock Grid.Row="1" Text="{Binding Name}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="80"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="4,4,4,6"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <TextBlock Grid.Column="1"
                                   Text="拖拽文件/文件夹到此处&#x0a;或点击 ＋ 添加"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding FilteredItems, Converter={StaticResource EmptyVis}}"/>
                    </Grid>

                    <!-- 边缘吸附收起时的细条指示（自由模式收起不显示） -->
                    <Border x:Name="CollapsedStripBorder"
                            Visibility="{Binding ShowEdgeCollapsedIndicator, Converter={StaticResource BoolVis}}"
                            Background="{StaticResource BgSecondaryBrush}"
                            CornerRadius="0,0,12,12"
                            ClipToBounds="True"
                            AllowDrop="True"
                            DragEnter="CollapsedStrip_DragEnter"
                            DragOver="CollapsedStrip_DragOver"
                            Drop="CollapsedStrip_Drop">
                        <Border Width="3"
                                Background="{StaticResource AccentBrush}"
                                HorizontalAlignment="{Binding CollapsedStripAlignment}"
                                Opacity="0.8"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
