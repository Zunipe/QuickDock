<Window x:Class="WpfApp1.Views.ItemEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="编辑项目" Height="395" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="编辑项目" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="名称" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="NameBox"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="路径" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="PathBox" IsReadOnly="True" Opacity="0.7"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="图标" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="64" Height="64" CornerRadius="12"
                            Background="{StaticResource BgTertiaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Image x:Name="IconPreview" Width="48" Height="48"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Button Content="选择自定义图标" Style="{StaticResource ModernButton}"
                                HorizontalAlignment="Left" Click="PickIcon_Click"/>
                        <Button Content="恢复默认图标" Style="{StaticResource ModernButton}"
                                HorizontalAlignment="Left" Margin="0,8,0,0" Click="ResetIcon_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource ModernButton}" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="保存" Style="{StaticResource AccentButton}" Width="80" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
