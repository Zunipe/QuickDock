<Window x:Class="WpfApp1.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:WpfApp1.Models"
        Style="{StaticResource ModernWindow}"
        Title="设置" Height="520" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="设置" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <TextBlock Text="常规" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="StartupCheckBox" Content="开机自启动（需要管理员权限）"/>

                    <Separator Margin="0,16" Background="{StaticResource BorderBrush}"/>

                    <TextBlock Text="边框吸附" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="EdgeSnapCheckBox" Content="启用边框吸附"/>

                    <TextBlock Text="吸附位置" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,6"/>
                    <ComboBox x:Name="SnapEdgeCombo">
                        <ComboBoxItem Content="左侧" Tag="{x:Static models:SnapEdge.Left}"/>
                        <ComboBoxItem Content="右侧" Tag="{x:Static models:SnapEdge.Right}"/>
                        <ComboBoxItem Content="自由位置" Tag="{x:Static models:SnapEdge.None}"/>
                    </ComboBox>

                    <Separator Margin="0,16" Background="{StaticResource BorderBrush}"/>

                    <TextBlock Text="呼出方式" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="SummonModeCombo">
                        <ComboBoxItem Content="靠近呼出" Tag="{x:Static models:SummonMode.Proximity}"/>
                        <ComboBoxItem Content="靠近 + 双击中键呼出" Tag="{x:Static models:SummonMode.ProximityMiddleDoubleClick}"/>
                    </ComboBox>

                    <TextBlock Text="靠近灵敏度 (像素)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ProximitySlider" Minimum="3" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" Text="{Binding ElementName=ProximitySlider, Path=Value, StringFormat={}{0:F0}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="提示：拖动窗口到屏幕边缘可自动吸附。启用边框吸附后，窗口会折叠到边缘。"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,16,0,0" FontSize="12"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="取消" Style="{StaticResource ModernButton}" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="保存" Style="{StaticResource AccentButton}" Width="80" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
